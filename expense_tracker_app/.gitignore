# ==============================================================
# FLUTTER / DART
# ==============================================================

# Dart tool cache (generated)
.dart_tool/
.pub-cache/
.pub/

# Flutter build output
/build/
/coverage/

# Flutter plugin dependencies (generated)
.flutter-plugins
.flutter-plugins-dependencies

# Dart generated files
*.g.dart
*.freezed.dart

# Flutter/Dart docs
**/doc/api/

# ==============================================================
# FIREBASE — SENSITIVE: mengandung API key dan project credentials
# ==============================================================

# Konfigurasi Firebase Android (berisi API key)
android/app/google-services.json

# Konfigurasi Firebase iOS (berisi API key)
ios/Runner/GoogleService-Info.plist

# File konfigurasi Firebase yang di-generate FlutterFire CLI
lib/firebase_options.dart

# ==============================================================
# ANDROID
# ==============================================================

# Path SDK lokal (spesifik per mesin, tidak boleh di-share)
android/local.properties

# Gradle cache dan build artifacts
android/.gradle/
android/.kotlin/
android/captures/
android/.cxx/

# Android build output
android/app/debug/
android/app/profile/
android/app/release/

# Keystore — JANGAN PERNAH di-push ke repository publik
android/key.properties
android/**/*.keystore
android/**/*.jks

# Generated plugin registrant
android/app/src/main/java/io/flutter/plugins/GeneratedPluginRegistrant.java

# ==============================================================
# iOS
# ==============================================================

# CocoaPods dependencies (di-generate saat `pod install`)
ios/Pods/
ios/.symlinks/

# Xcode build artifacts
ios/Flutter/App.framework/
ios/Flutter/Flutter.framework/
ios/Flutter/Flutter.podspec
ios/Flutter/Generated.xcconfig
ios/Flutter/ephemeral/
ios/Flutter/.last_build_id

# Generated plugin registrant
ios/Runner/GeneratedPluginRegistrant.h
ios/Runner/GeneratedPluginRegistrant.m

# Xcode user data
ios/**/*.xcworkspace/xcuserdata/
ios/**/*.xcodeproj/xcuserdata/
ios/**/*.xcodeproj/project.xcworkspace/

# ==============================================================
# IDE & EDITOR
# ==============================================================

# IntelliJ / Android Studio
*.iml
*.ipr
*.iws
.idea/

# VS Code (uncomment jika tidak ingin share launch config)
# .vscode/

# ==============================================================
# OS
# ==============================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~

# ==============================================================
# MISC
# ==============================================================

*.class
*.log
*.pyc
*.swp
.atom/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# Symbolication & obfuscation
app.*.symbols
app.*.map.json
